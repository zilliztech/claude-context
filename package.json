{
    "name": "claude-context",
    "version": "0.1.7",
    "description": "A powerful code indexing tool with multi-platform support",
    "private": true,
    "scripts": {
        "build": "pnpm -r --filter='!./examples/*' build && pnpm -r --filter='./examples/*' build",
        "build:core": "pnpm --filter @lbruton/claude-context-core build",
        "build:mcp": "pnpm --filter @lbruton/claude-context-mcp build",
        "dev": "pnpm -r dev",
        "dev:core": "pnpm --filter @lbruton/claude-context-core dev",
        "dev:mcp": "pnpm --filter @lbruton/claude-context-mcp dev",
        "clean": "pnpm -r clean",
        "lint": "pnpm -r lint",
        "lint:fix": "pnpm -r run lint:fix",
        "typecheck": "pnpm -r run typecheck",
        "release:core": "pnpm --filter @lbruton/claude-context-core... run build && pnpm --filter @lbruton/claude-context-core publish --access public --no-git-checks",
        "release:mcp": "pnpm --filter @lbruton/claude-context-mcp... run build && pnpm --filter @lbruton/claude-context-mcp publish --access public --no-git-checks",
        "example:basic": "pnpm --filter claude-context-basic-example start",
        "benchmark": "node scripts/build-benchmark.js"
    },
    "devDependencies": {
        "@types/node": "^20.19.37",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "eslint": "^9.39.4",
        "rimraf": "^6.1.3",
        "tree-sitter-cli": "^0.25.10",
        "typescript": "^5.9.3"
    },
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=10.0.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/lbruton/claude-context.git"
    },
    "pnpm": {
        "overrides": {
            "@langchain/core": ">=0.3.80",
            "langsmith": ">=0.4.6",
            "qs": ">=6.14.2"
        }
    },
    "license": "MIT",
    "author": "Cheney Zhang <277584121@qq.com>"
}